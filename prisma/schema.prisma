generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Movie {
  id        String   @id @default(cuid())
  title     String
  year      Int?
  coverUrl  String?
  doubanUrl String
  score     Int?     // 1-5
  review    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Movie {
  id           String   @id @default(cuid())
  title        String
  year         Int?
  coverUrl     String?
  doubanUrl    String
  doubanRating Float?   // 豆瓣评分
  summary      String?  @db.Text  // 作品简介（长文本）
  review       String?  // 个人短评
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

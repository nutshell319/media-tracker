generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Movie {
  id           String   @id @default(cuid())
  title        String
  year         Int?
  coverUrl     String?
  doubanUrl    String
  doubanRating Float?   // 豆瓣评分
  summary      String?  // 作品简介
  review       String?  // 个人短评
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
